# Pawven Environment Variables
# Copy this file to .env and fill in your values.
# Variables prefixed with EXPO_PUBLIC_ are available on the client side.

# REST API
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api

# MQTT Broker
EXPO_PUBLIC_MQTT_BROKER_URL=mqtt://localhost:1883

# Cloudinary (image uploads)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Clerk (authentication)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-key

# Mapbox (maps)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# Stripe (payments)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key
